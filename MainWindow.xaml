<Window x:Class="DesktopCountdown.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="桌面倒计时设置"
        Width="720"
        Height="620"
        MinWidth="640"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#1F2937" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="14,6" />
        </Style>
    </Window.Resources>
    <Grid Background="#F5F7FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="24,22" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="桌面倒计时" FontSize="24" FontWeight="SemiBold" />
                <TextBlock Text="设置目标时间、显示单位和悬浮窗外观。关闭此窗口后，悬浮窗会继续运行。"
                           Margin="0,8,0,0"
                           Foreground="#6B7280" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" Orientation="Vertical">
                <GroupBox Header="倒计时" Padding="16" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="标题" />
                        <TextBox x:Name="TitleBox" Grid.Column="1" />

                        <TextBlock Grid.Row="1" Text="目标日期" Margin="0,12,0,0" />
                        <DatePicker x:Name="TargetDatePicker" Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" />

                        <TextBlock Grid.Row="2" Text="目标时间" Margin="0,12,0,0" />
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,12,0,0">
                            <ComboBox x:Name="TargetHourBox" Width="80" />
                            <TextBlock Text="时" Margin="8,0,16,0" />
                            <ComboBox x:Name="TargetMinuteBox" Width="80" />
                            <TextBlock Text="分" Margin="8,0,16,0" />
                            <ComboBox x:Name="TargetSecondBox" Width="80" />
                            <TextBlock Text="秒" Margin="8,0,0,0" />
                        </StackPanel>

                        <TextBlock Grid.Row="3" Text="结束文案" Margin="0,12,0,0" />
                        <TextBox x:Name="EndTextBox" Grid.Row="3" Grid.Column="1" Margin="0,12,0,0" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="显示单位" Padding="16" Margin="0,0,0,16">
                    <WrapPanel>
                        <CheckBox x:Name="ShowDaysBox" Content="天" Margin="0,0,24,8" />
                        <CheckBox x:Name="ShowHoursBox" Content="时" Margin="0,0,24,8" />
                        <CheckBox x:Name="ShowMinutesBox" Content="分" Margin="0,0,24,8" />
                        <CheckBox x:Name="ShowSecondsBox" Content="秒" Margin="0,0,24,8" />
                        <CheckBox x:Name="CeilingDaysBox" Content="只显示天时向上取整" Margin="0,0,24,8" />
                    </WrapPanel>
                </GroupBox>

                <GroupBox Header="外观" Padding="16" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="背景模式" />
                        <ComboBox x:Name="BackgroundModeBox" Grid.Column="1" SelectedIndex="0">
                            <ComboBoxItem Content="液态玻璃" Tag="LiquidGlass" />
                            <ComboBoxItem Content="纯色" Tag="Solid" />
                            <ComboBoxItem Content="渐变" Tag="Gradient" />
                            <ComboBoxItem Content="图片" Tag="Image" />
                        </ComboBox>

                        <TextBlock Grid.Row="1" Text="背景颜色" Margin="0,12,0,0" />
                        <TextBox x:Name="BackgroundColorBox" Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" ToolTip="示例：#CCFFFFFF" />

                        <TextBlock Grid.Row="2" Text="文字颜色" Margin="0,12,0,0" />
                        <TextBox x:Name="TextColorBox" Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" ToolTip="示例：#FFFFFFFF" />

                        <TextBlock Grid.Row="3" Text="透明度" Margin="0,12,0,0" />
                        <Slider x:Name="OpacitySlider" Grid.Row="3" Grid.Column="1" Margin="0,12,0,0" Minimum="0.2" Maximum="1" TickFrequency="0.05" />

                        <TextBlock Grid.Row="4" Text="背景图片" Margin="0,12,0,0" />
                        <DockPanel Grid.Row="4" Grid.Column="1" Margin="0,12,0,0">
                            <Button Content="选择图片" DockPanel.Dock="Right" Margin="8,0,0,0" Click="ChooseImageButton_Click" />
                            <TextBox x:Name="BackgroundImageBox" IsReadOnly="True" />
                        </DockPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Header="行为" Padding="16">
                    <WrapPanel>
                        <CheckBox x:Name="TopmostBox" Content="始终置顶" Margin="0,0,24,8" />
                        <CheckBox x:Name="LockedBox" Content="锁定位置" Margin="0,0,24,8" />
                        <CheckBox x:Name="AutoStartBox" Content="开机自启" Margin="0,0,24,8" />
                        <CheckBox x:Name="NotifyOnEndBox" Content="结束时通知" Margin="0,0,24,8" />
                    </WrapPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="24,16">
            <DockPanel>
                <TextBlock x:Name="StatusText" Foreground="#6B7280" VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="隐藏悬浮窗" Margin="0,0,8,0" Click="HideWidgetButton_Click" />
                    <Button Content="保存并应用" FontWeight="SemiBold" Click="SaveButton_Click" />
                    <Button Content="退出应用" Margin="8,0,0,0" Click="ExitButton_Click" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
