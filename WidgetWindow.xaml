<Window x:Class="DesktopCountdown.WidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="300"
        Height="150"
        MinWidth="220"
        MinHeight="110"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        LocationChanged="Window_LocationChanged"
        SizeChanged="Window_SizeChanged"
        Closing="Window_Closing">
    <Grid>
        <Border x:Name="RootBorder"
                CornerRadius="18"
                Padding="18"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.22" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock x:Name="TitleText"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <ItemsControl x:Name="CountdownItems"
                              Grid.Row="1"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="6,0" HorizontalAlignment="Center" MinWidth="28">
                                <TextBlock Text="{Binding Value}"
                                           FontWeight="Bold"
                                           TextAlignment="Center"
                                           FontFamily="Consolas"
                                           MinWidth="20" />
                                <TextBlock Text="{Binding Unit}"
                                           TextAlignment="Center"
                                           Opacity="0.82"
                                           MinWidth="20" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock x:Name="TargetText"
                           Grid.Row="2"
                           Opacity="0.78"
                           TextAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>
